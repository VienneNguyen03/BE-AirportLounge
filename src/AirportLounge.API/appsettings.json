{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=airport_lounge;Username=postgres;Password=postgres",
    "Redis": ""
  },
  "Jwt": {
    "Secret": "YourSuperSecretKeyHereMustBeAtLeast32Characters!",
    "Issuer": "AirportLounge.API",
    "Audience": "AirportLounge.Client",
    "AccessTokenExpirationMinutes": "60",
    "RefreshTokenExpirationDays": "7"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "http://localhost:8080",
      "http://127.0.0.1:8080"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  },
  "AllowedHosts": "*"
}